<odoo>
    <record id="view_order_form_licitaciones" model="ir.ui.view">
        <field name="name">sale.order.form.licitaciones</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>

        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">

                <group string="Información Licitación">
                    <field name="numero_licitacion"/>
                    <field name="entidad_estatal"/>
                    <field name="fecha_adjudicacion"/>
                </group>

            </xpath>
        </field>
    </record>
</odoo>